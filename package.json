{
  "name": "enovis-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Enovis - Productivity Management System Monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start --workspaces --if-present",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules",
    "web:dev": "npm run dev --workspace=apps/web",
    "web:build": "npm run build --workspace=apps/web",
    "web:start": "npm run start --workspace=apps/web",
    "server:dev": "npm run dev --workspace=apps/server",
    "server:build": "npm run build --workspace=apps/server",
    "server:start": "npm run start --workspace=apps/server",
    "server:db:init": "npm run db:init --workspace=apps/server"
  },
  "keywords": [
    "monorepo",
    "productivity",
    "management",
    "system"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
